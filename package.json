{
  "name": "rrssagente-workspace",
  "version": "2.0.0",
  "private": true,
  "description": "Suite de Growth Marketing con Servidores MCP locales",
  "workspaces": [
    "servers/shared",
    "servers/social-manager",
    "servers/paid-ads-expert",
    "servers/analytics-core"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "build": "tsc && npm run build --workspaces --if-present",
    "start:dashboard": "node dist/dashboard/server.js",
    "social-manager": "node servers/social-manager/dist/index.js",
    "paid-ads-expert": "node servers/paid-ads-expert/dist/index.js",
    "analytics-core": "node servers/analytics-core/dist/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.9",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.11"
  }
}
